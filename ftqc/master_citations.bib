@article{HO2011797,
title = {Dirac(-Pauli), Fokker–Planck equations and exceptional Laguerre polynomials},
journal = {Annals of Physics},
volume = {326},
number = {4},
pages = {797-807},
year = {2011},
issn = {0003-4916},
