author = {S A Newlove},
title = {High-order behaviour of the critical exponents for the scalar ϕ3 model with imaginary coupling},
journal = {Journal of Physics A: Mathematical and General},
abstract = {For real coupling constants the vertex functions for the phi 3 model have a real and imaginary part. The author presents a method of renormalising both parts of the vertex functions for small coupling g0. A consequence of the method is that the renormalisation group functions develop a non-perturbative imaginary part. This leads to an imaginary part for the critical exponents valid for 6-d= epsilon &lt;0, where d is the dimension of the space. A dispersion relation in epsilon then yields the high-order behaviour of the critical exponents as a power series in epsilon . In particular the values of the overall universal coefficients, c, of the factorial growth are obtained.}
}

