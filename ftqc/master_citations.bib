% --- converted from: 10.1038_nature08482-citation.ris ---
@article{Bakr2009,
  author = {Bakr, Waseem S. and Gillen, Jonathon I. and Peng, Amy and Fölling, Simon and Greiner, Markus},
  title = {A quantum gas microscope for detecting single atoms in a Hubbard-regime optical lattice},
  journal = {Nature},
  year = {2009},
