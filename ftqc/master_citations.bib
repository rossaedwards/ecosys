% --- converted from: 10.1038_nature12066-citation.ris ---
@article{Rechtsman2013,
  author = {Rechtsman, Mikael C. and Zeuner, Julia M. and Plotnik, Yonatan and Lumer, Yaakov and Podolsky, Daniel and Dreisow, Felix and Nolte, Stefan and Segev, Mordechai and Szameit, Alexander},
  title = {Photonic Floquet topological insulators},
