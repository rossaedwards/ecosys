\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Hilbert space scaling comparison between classical Euclidean lattices ($2^N$, dashed) and fractal Sierpi\'{n}ski topology ($2^{N \cdot 1.585}$, solid). The shaded region indicates the fractal advantage, reaching $5.8 \times 10^1$ at $N = 12$ qubits for the simplified model ($k = 1$). Full hierarchical coupling at $k = 3$ extends this to $10^4\times $ per Theorem~\ref {thm:main}. Simulation: tight-binding model with NetworkX Laplacian eigenvalue analysis.}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:hilbert_scaling}{{1}{7}{Hilbert space scaling comparison between classical Euclidean lattices ($2^N$, dashed) and fractal Sierpi\'{n}ski topology ($2^{N \cdot 1.585}$, solid). The shaded region indicates the fractal advantage, reaching $5.8 \times 10^1$ at $N = 12$ qubits for the simplified model ($k = 1$). Full hierarchical coupling at $k = 3$ extends this to $10^4\times $ per Theorem~\ref {thm:main}. Simulation: tight-binding model with NetworkX Laplacian eigenvalue analysis}{figure.1}{}}
