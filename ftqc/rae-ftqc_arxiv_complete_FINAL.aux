\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Anderson localization of edge states on a Sierpi\'{n}ski gasket at recursion depth $k = 6$. Color intensity represents wavefunction amplitude $|\psi (x)|^2$, with exponential decay $|\psi | \propto \exp (-x/\xi )$ from the apex (dark) to the base (light). The localization length $\xi \approx 0.3 L$ (where $L$ is the lattice linear dimension) demonstrates strong confinement characteristic of $d_s < 2$ spectral dimension. This localization underlies the decoherence suppression in Fig.~\ref {fig:coherence}.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:localization}{{3}{8}{Anderson localization of edge states on a Sierpi\'{n}ski gasket at recursion depth $k = 6$. Color intensity represents wavefunction amplitude $|\psi (x)|^2$, with exponential decay $|\psi | \propto \exp (-x/\xi )$ from the apex (dark) to the base (light). The localization length $\xi \approx 0.3 L$ (where $L$ is the lattice linear dimension) demonstrates strong confinement characteristic of $d_s < 2$ spectral dimension. This localization underlies the decoherence suppression in Fig.~\ref {fig:coherence}}{figure.3}{}}
