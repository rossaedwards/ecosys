@article{
doi:10.1126/science.1116955,
author = {J. R. Petta  and A. C. Johnson  and J. M. Taylor  and E. A. Laird  and A. Yacoby  and M. D. Lukin  and C. M. Marcus  and M. P. Hanson  and A. C. Gossard },
title = {Coherent Manipulation of Coupled Electron Spins in Semiconductor Quantum Dots},
journal = {Science},
volume = {309},
