@article{Lewenstein01032007,
author = {Maciej Lewenstein and Anna Sanpera and Veronica Ahufinger and Bogdan Damski and Aditi Sen(De) and Ujjwal Sen},
title = {Ultracold atomic gases in optical lattices: mimicking condensed matter physics and beyond},
journal = {Advances in Physics},
