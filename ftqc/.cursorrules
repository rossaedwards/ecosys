pdflatex -interaction=nonstopmode rae-ftqc_arxiv_complete.tex
bibtex rae-ftqc_arxiv_complete
pdflatex -interaction=nonstopmode rae-ftqc_arxiv_complete.tex
pdflatex -interaction=nonstopmode rae-ftqc_arxiv_complete.tex

# Test 2: Verify PDF output
# - Open rae-ftqc_arxiv_complete.pdf
# - Check all figures render
# - Check no "??" in citations
# - Count pages (should be ~40)

# Test 3: Clean PRX build
rm -f rae-ftqc_prx_submission.aux rae-ftqc_prx_submission.bbl rae-ftqc_prx_submission.blg
pdflatex -interaction=nonstopmode rae-ftqc_prx_submission.tex
bibtex rae-ftqc_prx_submission
pdflatex -interaction=nonstopmode rae-ftqc_prx_submission.tex
pdflatex -interaction=nonstopmode rae-ftqc_prx_submission.tex

# Test 4: Verify PRX constraints
# - Page count ≤12
# - Exactly 75 references in bibliography
